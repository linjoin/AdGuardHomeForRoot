    "rules": [
      {
        "rule_set": [
        "awavenue",
        "007-ads-all",
        "cn-ads",
        "ads-Local"
        ],
        "action": "predefined",
        "rcode": "NOERROR"
      },
      
      {
        "query_type": [
          "SRV",
          "HTTPS"
        ],
        "action": "predefined",
        "rcode": "NXDOMAIN"
      },
     
      {
        "domain_regex": "^(\\d{1,3}\\.){3}\\d{1,3}$",
        "action": "predefined",
        "rcode": "NXDOMAIN"
      },
      
      {
        "domain_keyword": [
          "ntp",
          "time"
        ],
        "server": "direct-group"
      },
      {
        "rule_set": [
          "cn_domain",
          "private_domain",
          "geosite-bilibili"
        ],
        "server": "direct-group"
      },
      
      {
        "query_type": [
          "A",
          "AAAA"
        ],
        "server": "FAKEIP-DNS",
        "rewrite_ttl": 1
      },
      {
        "clash_mode": "Direct",
        "server": "direct-group"
      },
      {
        "clash_mode": "Global",
        "server": "proxy-group"
      }
    ],
    "final": "proxy-group",
    "reverse_mapping": true,
    "strategy": "prefer_ipv4",
    "independent_cache": true
