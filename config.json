  "providers": [
    {
      "type": "remote",
      "tag": "main",
      "url": "订阅地址",
      "exclude": "剩余流量|到期|重置|官网",
      "user_agent": "sing-box",
      "path": "./proxy_provider/provider1.json",
      "download_detour": "🚀 节点选择"
    },
    {
      "type": "remote",
      "tag": "Secondary",
      "url": "订阅地址",
      "exclude": "剩余流量|到期|重置|官网",
